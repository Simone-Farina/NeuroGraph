# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Only required for local E2E/test helper utilities (not required by app runtime)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── AI Model Configuration ───────────────────────────────────────────────────
# Each agent role has its own model, configured independently.
# Format: provider:model-name   (e.g. openai:gpt-4o-mini, anthropic:claude-3-5-haiku-20241022)
# Supported providers: openai | anthropic | google
#
# Set AI_PROVIDER=mock to bypass all AI calls with test stubs (local dev / CI).
AI_PROVIDER=

# Chat assistant — streaming, supports tools (neurogenesis suggestions, RAG)
AI_MODEL_CHAT=openai:gpt-4o

# Synthesis — fast model for in-place content editing via /api/neurons/[id]/synthesize
AI_MODEL_SYNTHESIS_FAST=openai:gpt-4o-mini

# Neurogenesis — heavier model for creating high-quality neuron nodes from conversation
AI_MODEL_NEUROGENESIS_HEAVY=openai:gpt-4o

# Evaluator — background tasks (e.g. Carica Sinaptica, auto-tagging)
AI_MODEL_EVALUATOR=openai:gpt-4o-mini
# ──────────────────────────────────────────────────────────────────────────────

# API Keys — only the keys for providers you configure above are required
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
GOOGLE_API_KEY=your-google-api-key-here

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
